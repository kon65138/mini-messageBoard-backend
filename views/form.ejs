<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <h1><%= title %></h1>
    <%- include("partials/errors.ejs") %>
    <form id="signUpForm" method="POST" action="/new">
      <h2 class="formTitle">New message form</h2>
      <label for="messageName"
        >name:
        <input type="text" , id="messageName" name="messageName" required />
      </label>
      <label for="messageBody"
        >text:
        <input type="text" , id="messageBody" name="messageBody" required />
      </label>
      <button type="submit">Submit</button>
    </form>
  </body>
</html>
